DATABASE_URL=postgres://valvetech:valvetech@localhost:5432/valvetech

# Upstream JSON-RPC for both /rpc proxy and internal viem queries.
# In production this should point at the private Valve RPC; locally the
# public endpoint is fine. Format: https://rpc.valve.city/v1/<key>/evm/369
PULSECHAIN_RPC_URL=https://rpc.pulsechain.com

# Debug-enabled node (debug_*/ots_* namespaces). Defaults to PULSECHAIN_RPC_URL
# when unset. Use the private Valve URL here as well in production.
DEBUG_RPC_URL=

BLOCKSCOUT_API_URL=https://api.scan.pulsechain.com/api
PORT=10100
