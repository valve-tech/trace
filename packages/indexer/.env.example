# RPC for the chain being indexed. Use the Valve reth fleet (archive) so
# seed-on-first-sight balanceOf reads at historical blocks succeed.
PULSECHAIN_RPC_URL=https://rpc.pulsechain.com

# Shared Postgres — the indexer writes to its own `indexer` schema, isolated
# from the API's migrations.
DATABASE_URL=postgres://valvetech:valvetech@localhost:5432/valvetech

# Block to begin indexing from. Recent keeps the initial sync fast + the index
# small; balances stay correct via seed-on-first-sight. Lower it to capture
# more historical holders (more storage + longer sync).
INDEXER_START_BLOCK=26600000

# Ponder's HTTP server port (GraphQL + SQL). The API queries this / the shared
# Postgres schema for holdings.
PORT=42069
