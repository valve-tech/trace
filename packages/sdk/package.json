{
  "name": "@valve-tech/trace-sdk",
  "version": "0.2.0",
  "description": "Standalone EVM trace loading, traversal, and rendering toolkit. No platform dependencies.",
  "keywords": [
    "evm",
    "trace",
    "pulsechain",
    "ethereum",
    "debugger",
    "flamegraph",
    "gas-profiler",
    "react"
  ],
  "homepage": "https://github.com/valve-tech/trace/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/valve-tech/trace/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valve-tech/trace.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "author": "Valve Tech <dev@valve.city>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./loaders": {
      "types": "./dist/loaders/index.d.ts",
      "import": "./dist/loaders/index.js"
    },
    "./traversal": {
      "types": "./dist/traversal/index.d.ts",
      "import": "./dist/traversal/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./parsers": {
      "types": "./dist/parsers/index.d.ts",
      "import": "./dist/parsers/index.js"
    },
    "./risks": {
      "types": "./dist/risks/index.d.ts",
      "import": "./dist/risks/index.js"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "import": "./dist/templates/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "viem": "^2.23.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.2.6",
    "typescript": "^5.7.3",
    "viem": "^2.23.2",
    "vitest": "^4.1.1"
  },
  "sideEffects": false
}
