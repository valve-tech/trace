{
  "name": "@valve-tech/explore-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:ipfs": "tsc -b && VITE_IPFS=1 VITE_API_BASE=https://explore.valve.city vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:spacing": "if grep -rnE '(^|[^a-zA-Z0-9_-])(gap-[1235]|space-y-[4-8])([^.0-9-]|$)' src --include='*.tsx' --include='*.ts'; then echo '\\nBanned Tailwind spacing class found above. Use semantic tokens: gap-tight | gap-inline | gap-row | space-y-stack | space-y-section. Defined in src/index.css. (Half-steps like gap-1.5 are allowed.)'; exit 1; fi"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@tanstack/query-persist-client-core": "^5.95.2",
    "@tanstack/query-sync-storage-persister": "^5.95.2",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-persist-client": "^5.95.2",
    "@valve-tech/auth-lite": "^0.18.0",
    "@valve-tech/trace-sdk": "*",
    "@valve-tech/wallet-crypto": "^0.18.0",
    "idb-keyval": "^6.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "viem": "^2.23.0",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^4.1.1"
  }
}
